<Application x:Class="Easydict.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8DEE8" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#162033" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#5E6A7D" />
    </Application.Resources>
</Application>
