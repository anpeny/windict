<Window x:Class="Easydict.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easydict Windows"
        Width="680"
        Height="620"
        MinWidth="480"
        MinHeight="520"
        Background="{StaticResource PanelBackgroundBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Easydict Windows"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryTextBrush}" />
            <TextBlock Margin="0,8,0,0"
                       Text="Ctrl+Alt+A 输入，Ctrl+Alt+D 划词，Ctrl+Alt+S 截图 OCR"
                       Foreground="{StaticResource SecondaryTextBrush}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      Margin="0,24"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="18"
                        CornerRadius="8"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        Background="White">
                    <StackPanel>
                        <TextBlock Text="快捷操作"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" />
                        <WrapPanel Margin="0,14,0,0">
                            <Button Width="160"
                                    Margin="0,0,12,12"
                                    Content="打开查询浮窗"
                                    Click="OpenLookupButton_Click" />
                            <Button Width="160"
                                    Margin="0,0,12,12"
                                    Content="截图并 OCR"
                                    Click="CaptureOcrButton_Click" />
                            <Button Width="160"
                                    Margin="0,0,12,12"
                                    Content="区域截图 OCR"
                                    Click="RegionOcrButton_Click" />
                            <Button Width="160"
                                    Margin="0,0,12,12"
                                    Content="静默 OCR"
                                    Click="SilentOcrButton_Click" />
                            <Button Width="160"
                                    Margin="0,0,12,12"
                                    Content="查询历史"
                                    Click="HistoryButton_Click" />
                        </WrapPanel>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{StaticResource SecondaryTextBrush}">
                            浮窗使用 Win32 非激活样式显示，支持快捷键读取选中文字，并可通过托盘后台运行。
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="18"
                        CornerRadius="8"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        Background="White">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.ColumnSpan="2"
                                   Text="自定义翻译服务"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,18,12,0"
                                   VerticalAlignment="Center"
                                   Text="API URL" />
                        <TextBox x:Name="ApiUrlTextBox"
                                 Grid.Row="1"
                                 Grid.Column="1"
                                 Margin="0,18,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Authorization" />
                        <PasswordBox x:Name="AuthTokenBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     Margin="0,12,0,0"
                                     MinHeight="30" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Query Field" />
                        <TextBox x:Name="QueryFieldTextBox"
                                 Grid.Row="3"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <CheckBox x:Name="JsonBodyCheckBox"
                                  Grid.Row="4"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  Content="Use JSON request body" />

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Result Path" />
                        <TextBox x:Name="ResultPathTextBox"
                                 Grid.Row="5"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="6"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Source Lang" />
                        <TextBox x:Name="SourceLanguageTextBox"
                                 Grid.Row="6"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="7"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Target Lang" />
                        <TextBox x:Name="TargetLanguageTextBox"
                                 Grid.Row="7"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="8"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Input Hotkey" />
                        <TextBox x:Name="InputHotkeyTextBox"
                                 Grid.Row="8"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="9"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Lookup Hotkey" />
                        <TextBox x:Name="LookupHotkeyTextBox"
                                 Grid.Row="9"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="10"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="OCR Hotkey" />
                        <TextBox x:Name="OcrHotkeyTextBox"
                                 Grid.Row="10"
                                 Grid.Column="1"
                                 Margin="0,12,0,0"
                                 MinHeight="30" />

                        <TextBlock Grid.Row="11"
                                   Margin="0,12,12,0"
                                   VerticalAlignment="Center"
                                   Text="Silent OCR Hotkey" />
                        <TextBox x:Name="SilentOcrHotkeyTextBox"
                                  Grid.Row="11"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  MinHeight="30" />

                        <CheckBox x:Name="LaunchAtLoginCheckBox"
                                  Grid.Row="12"
                                  Grid.Column="1"
                                  Margin="0,12,0,0"
                                  Content="Start Easydict when Windows starts" />

                        <StackPanel Grid.Row="13"
                                    Grid.Column="1"
                                    Margin="0,16,0,0"
                                    Orientation="Horizontal">
                            <Button Width="120"
                                    Content="保存设置"
                                    Click="SaveSettingsButton_Click" />
                            <Button Width="120"
                                    Margin="12,0,0,0"
                                    Content="测试服务"
                                    Click="TestServiceButton_Click" />
                            <Button Width="140"
                                    Margin="12,0,0,0"
                                    Content="套用题库接口"
                                    Click="ApplyQuestionPresetButton_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <TextBlock x:Name="StatusText"
                   Grid.Row="2"
                   Text="已就绪"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource SecondaryTextBrush}" />
    </Grid>
</Window>
