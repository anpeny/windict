<Window x:Class="Easydict.Windows.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easydict History"
        Width="720"
        Height="520"
        MinWidth="560"
        MinHeight="380"
        Background="#F8FAFC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel>
            <TextBlock Text="查询历史"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="#162033" />
            <Button DockPanel.Dock="Right"
                    Width="96"
                    Content="清空"
                    Click="ClearButton_Click" />
        </DockPanel>

        <ListBox x:Name="HistoryListBox"
                 Grid.Row="1"
                 Margin="0,16,0,16"
                 BorderBrush="#D8DEE8"
                 BorderThickness="1"
                 MouseDoubleClick="HistoryListBox_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="12"
                            BorderBrush="#E5E7EB"
                            BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="{Binding CreatedAt}"
                                       FontSize="12"
                                       Foreground="#64748B" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding Query}"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Foreground="#162033" />
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding Result}"
                                       MaxHeight="72"
                                       TextWrapping="Wrap"
                                       Foreground="#334155" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2"
                   Text="双击一条记录可复制查询内容。"
                   Foreground="#64748B" />
    </Grid>
</Window>

